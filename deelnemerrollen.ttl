@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rol: <https://ori-a.nl/begrippenlijsten#deelnemerrollen-> .

<https://ori-a.nl/begrippenlijsten#deelnemerrollen> a skos:ConceptScheme ;
    dcterms:title "Deelnemerrollen"@nl ;
    dcterms:description "Rollen waarin in een deelnemer aan een vergadering aanwezig in kan zijn."@nl ;
    skos:hasTopConcept rol:voorzitter, rol:viceVoorzitter, rol:portefeuillehouder, rol:griffier,
        rol:statenlid, rol:kamerlid, rol:dagelijksBestuurslid, rol:algemeenBestuurslid,
        rol:inspreker, rol:overig .
    

rol:voorzitter a skos:Concept ;
    skos:topConceptOf <https://ori-a.nl/begrippenlijsten#deelnemerrollen> ;
    skos:prefLabel "Voorzitter"@nl ;
    skos:definition "De voorzitter van de vergadering."@nl .

# not "vice-voorzitter" because python disallows hyphens
rol:viceVoorzitter a skos:Concept ;
    skos:topConceptOf <https://ori-a.nl/begrippenlijsten#deelnemerrollen> ;
    skos:prefLabel "Vice-voorzitter"@nl ;
    skos:definition "De vice-voorzitter van de vergadering."@nl .

rol:portefeuillehouder a skos:Concept ;
    skos:topConceptOf <https://ori-a.nl/begrippenlijsten#deelnemerrollen> ;
    skos:prefLabel "Portefeuillehouder"@nl ;
    skos:definition "Ambtenaar die de verantwoordelijkheid draagt over een besproken onderwerp."@nl .

rol:griffier a skos:Concept ;
    skos:topConceptOf <https://ori-a.nl/begrippenlijsten#deelnemerrollen> ;
    skos:prefLabel "Griffier"@nl ;
    skos:definition "Hoofd van de griffie."@nl .

rol:raadslid a skos:Concept ;
    skos:topConceptOf <https://ori-a.nl/begrippenlijsten#deelnemerrollen> ;
    skos:prefLabel "Raadslid"@nl ;
    skos:definition "Gekozen volksvertegenwoordiger binnen een gemeente."@nl .

rol:statenlid a skos:Concept ;
    skos:topConceptOf <https://ori-a.nl/begrippenlijsten#deelnemerrollen> ;
    skos:prefLabel "Statenlid"@nl ;
    skos:definition "Gekozen volksvertegenwoordiger binnen een provincie."@nl .

rol:kamerlid a skos:Concept ;
    skos:topConceptOf <https://ori-a.nl/begrippenlijsten#deelnemerrollen> ;
    skos:prefLabel "Kamerlid"@nl ;
    skos:definition "Gekozen volksvertegenwoordiger binnen de Eerste of Tweede Kamer."@nl .

rol:dagelijksBestuurslid a skos:Concept ;
    skos:topConceptOf <https://ori-a.nl/begrippenlijsten#deelnemerrollen> ;
    skos:prefLabel "Dagelijks bestuurslid"@nl ;
    skos:definition "Lid van een dagelijks bestuur."@nl .

rol:algemeenBestuurslid a skos:Concept ;
    skos:topConceptOf <https://ori-a.nl/begrippenlijsten#deelnemerrollen> ;
    skos:prefLabel "Algemeen bestuurslid"@nl ;
    skos:definition "Lid van een algemeen bestuur."@nl .

rol:inspreker a skos:Concept ;
    skos:topConceptOf <https://ori-a.nl/begrippenlijsten#deelnemerrollen> ;
    skos:prefLabel "Inspreker"@nl ;
    skos:definition "Niet-lid dat inspreekt tijdens de vergadering."@nl .

# todo: maybe add a `replacedBy`, and then link the most generic term
# (linking to generic concepts is also a good way of mapping ORI and ORI-A in general)
rol:overig a skos:Concept ;
    skos:topConceptOf <https://ori-a.nl/begrippenlijsten#deelnemerrollen> ;
    owl:deprecated true ;
    skos:prefLabel "Overig"@nl ;
    dcterms:description "Slechts aanwezig tbv compatibiliteit met het oorspronkelijke ORI informatiemodel; gebruik van deze rol wordt afgeraden." .
